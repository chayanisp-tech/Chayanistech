rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Exams rules
    match /exams/{examId} {
      allow read: if true; // Allowed for students to retrieve exams
      allow write: if request.auth != null; // Only authenticated teachers can edit exams
    }

    // Students rules
    match /students/{studentId} {
      allow read: if true; // Allowed for student validation
      allow write: if request.auth != null; // Only teachers can edit student lists
    }

    // Settings rules
    match /settings/{docId} {
      allow read: if true; // Students need settings (e.g. lockdown, durations)
      allow write: if request.auth != null; // Only teachers can save settings
    }

    // Submissions rules
    match /submissions/{submissionId} {
      allow create: if true; // Anyone can submit an exam
      allow read: if true; // Student lookup or teacher list
      allow update, delete: if request.auth != null; // Only teachers can grade or delete submissions
    }
  }
}
